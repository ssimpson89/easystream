# EasyStream configuration — copy to .env and fill in your values.
# .env is gitignored; .env.example is the template that lives in the repo.

# --- HTTP server ---
# Where the EasyStream web UI listens.
# Default: 127.0.0.1:8080 (localhost only — change with care)
# EASYSTREAM_ADDR=127.0.0.1:8080

# --- Data directory ---
# Where persisted state lives: tokens, schedules, stream config, HLS segments.
# Default: ~/.easystream
# EASYSTREAM_DATA_DIR=/path/to/data

# --- YouTube OAuth (optional) ---
# Required only if you want scheduled broadcasts, "Go Live Now", or YouTube
# health polling. Without these, manual RTMP/RTMPS still works.
#
# Get these from Google Cloud Console:
#   1. https://console.cloud.google.com → create a project
#   2. APIs & Services → Library → enable "YouTube Data API v3"
#   3. APIs & Services → Credentials → Create OAuth client ID
#      - Type: Web application
#      - Authorized redirect URI: http://127.0.0.1:8080/api/youtube/auth/callback
#   4. Paste the resulting Client ID and Client Secret below.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
